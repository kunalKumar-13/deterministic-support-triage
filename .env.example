# Copy to .env. The .env file is gitignored.
# At least one LLM key is recommended but not required — the pipeline runs
# deterministically without an LLM (heuristic fallback path).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides
TRIAGE_LLM_PROVIDER=auto          # auto | anthropic | openai | off
TRIAGE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
TRIAGE_OPENAI_MODEL=gpt-4o-mini
TRIAGE_LOG_LEVEL=INFO
